# GoToSocial instance the bot account lives on.
MASTODON_INSTANCE_URL=https://social.zxplay.org
# Access token for the bot account (create via the GoToSocial settings panel).
MASTODON_ACCESS_TOKEN=
# Internal URL of the gif-service container.
GIF_SERVICE_URL=http://gif-service:5001
# Where to persist the last-processed notification id.
STATE_FILE=/data/state.json
# How often to poll for new mentions.
POLL_INTERVAL_MS=15000
# Capture and size limits.
MAX_SECONDS=30
MAX_MEDIA_BYTES=8000000
# Optional text posted alongside the video (leave empty for media-only replies).
REPLY_CAPTION=
# Set true to log what would run without posting anything.
DRY_RUN=false
